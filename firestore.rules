rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // App personal de un solo usuario: solo la cuenta de Roberto puede leer/escribir.
    // Cubre todo: cartera/*, gastos, ingresos, transferencias y colecciones futuras.
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'rl7103405@gmail.com';
    }
  }
}
